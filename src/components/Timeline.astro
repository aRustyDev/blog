---
import dayjs from "dayjs";

interface TimelineItem {
  date: string;
  label: string;
  description?: string;
  url?: string;
  icon?: string;
}

type Props = {
  items: TimelineItem[];
  orientation?: "vertical" | "horizontal";
  collapsible?: boolean;
  class?: string;
};

const {
  items,
  orientation = "vertical",
  collapsible = true,
  class: className,
} = Astro.props;

function formatDate(date: string): string {
  // Quarter format: "2025-Q3" → "Q3 2025"
  if (date.includes("-Q")) {
    const [year, quarter] = date.split("-");
    return `${quarter} ${year}`;
  }
  return dayjs(date).format("MMM D, YYYY");
}

function formatShort(date: string): string {
  if (date.includes("-Q")) {
    const [, quarter] = date.split("-");
    return quarter;
  }
  return dayjs(date).format("MMM D");
}

const firstDate = items.length > 0 ? formatDate(items[0].date) : "";
const lastDate = items.length > 1 ? formatDate(items[items.length - 1].date) : firstDate;
const summaryLabel = `Timeline: ${firstDate} — ${lastDate}`;
const isVertical = orientation === "vertical";
---

{collapsible ? (
  <details class:list={["component-details", "timeline-wrapper", className]} open>
    <summary class="timeline-summary" aria-label={summaryLabel}>
      <span class="timeline-chevron" aria-hidden="true"></span>
      <span class="timeline-summary-text">{firstDate} — {lastDate}</span>
    </summary>
    {isVertical ? (
      <div class="timeline-vertical">
        {items.map(item => (
          <div class="timeline-item">
            <span class="timeline-dot" aria-hidden="true"></span>
            <div class="timeline-date">{formatDate(item.date)}</div>
            <div class="timeline-label">
              {item.url ? (
                <a href={item.url} target="_blank" rel="noopener noreferrer">{item.label}</a>
              ) : (
                item.label
              )}
            </div>
            {item.description && <div class="timeline-description">{item.description}</div>}
          </div>
        ))}
      </div>
    ) : (
      <div class="timeline-horizontal">
        {items.map(item => (
          <div class="timeline-h-item">
            <span class="timeline-h-dot" aria-hidden="true"></span>
            <div class="timeline-h-date">{formatShort(item.date)}</div>
            <div class="timeline-h-label">
              {item.url ? (
                <a href={item.url} target="_blank" rel="noopener noreferrer">{item.label}</a>
              ) : (
                item.label
              )}
            </div>
          </div>
        ))}
      </div>
    )}
  </details>
) : (
  <div class:list={["timeline-wrapper", className]}>
    {isVertical ? (
      <div class="timeline-vertical">
        {items.map(item => (
          <div class="timeline-item">
            <span class="timeline-dot" aria-hidden="true"></span>
            <div class="timeline-date">{formatDate(item.date)}</div>
            <div class="timeline-label">
              {item.url ? (
                <a href={item.url} target="_blank" rel="noopener noreferrer">{item.label}</a>
              ) : (
                item.label
              )}
            </div>
            {item.description && <div class="timeline-description">{item.description}</div>}
          </div>
        ))}
      </div>
    ) : (
      <div class="timeline-horizontal">
        {items.map(item => (
          <div class="timeline-h-item">
            <span class="timeline-h-dot" aria-hidden="true"></span>
            <div class="timeline-h-date">{formatShort(item.date)}</div>
            <div class="timeline-h-label">
              {item.url ? (
                <a href={item.url} target="_blank" rel="noopener noreferrer">{item.label}</a>
              ) : (
                item.label
              )}
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
)}
