---
type Props = {
  items: { label: string; description?: string }[];
  class?: string;
};

const { items, class: className } = Astro.props;
---

<div class:list={["timeline-process", className]}>
  {items.map((item, i) => (
    <div class="timeline-step-group">
      <div class="timeline-step">
        <span class="timeline-step-number">{i + 1}</span>
      </div>
      <div class="timeline-step-label">{item.label}</div>
      {item.description && <div class="timeline-step-desc">{item.description}</div>}
      {i < items.length - 1 && (
        <div class="timeline-arrow" aria-hidden="true"></div>
      )}
    </div>
  ))}
</div>
