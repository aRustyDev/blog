---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconArchive from "@/assets/icons/IconArchive.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";

const { pathname } = Astro.url;

// Remove trailing slash from current pathname if exists
const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());

  return currentPath === path || currentPathArray[0] === pathArray[0];
};
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 bg-bg px-3 py-2 text-ac backdrop-blur-lg transition-all focus:top-4"
>
  Skip to content
</a>

<header
  class="w-full border-b border-bd bg-bg"
>
  <div
    id="top-nav-wrap"
    class:list={[
      "py-4 sm:py-6 px-4",
      "mx-auto w-full max-w-[80rem]",
      "relative",
      "flex items-baseline justify-between sm:items-center",
    ]}
  >
    <a
      href="/"
      class="absolute py-1 text-xl leading-8 font-semibold whitespace-nowrap sm:static sm:my-auto sm:text-2xl sm:leading-none"
    >
      {SITE.title}
    </a>
    {/* Collapsible nav links — hidden on mobile, hamburger toggles */}
    <nav
      id="nav-menu"
      class="flex flex-1 flex-col items-center sm:ms-2 sm:flex-row sm:justify-end sm:py-0"
    >
      <button
        id="menu-btn"
        class="focus-outline self-end p-2 sm:hidden"
        aria-label="Open Menu"
        aria-expanded="false"
        aria-controls="menu-items"
      >
        <IconX id="close-icon" class="hidden" />
        <IconMenuDeep id="menu-icon" />
      </button>
      <ul
        id="menu-items"
        class:list={[
          "mt-4 grid w-44 grid-cols-2 place-content-center gap-2",
          "[&>li>a]:block [&>li>a]:px-4 [&>li>a]:py-3 [&>li>a]:text-center [&>li>a]:font-medium [&>li>a]:hover:text-ac sm:[&>li>a]:px-2 sm:[&>li>a]:py-1",
          "hidden",
          "sm:mt-0 sm:flex sm:w-auto sm:gap-x-5 sm:gap-y-0",
        ]}
      >
        <li class="col-span-2">
          <a href="/posts" class:list={{ "active-nav": isActive("/posts") }}>
            Posts
          </a>
        </li>
        <li class="col-span-2">
          <a href="/tags" class:list={{ "active-nav": isActive("/tags") }}>
            Tags
          </a>
        </li>
        <li class="col-span-2">
          <a href="/graph" class:list={{ "active-nav": isActive("/graph") }}>
            Graph
          </a>
        </li>
        <li class="col-span-2">
          <a href="/about" class:list={{ "active-nav": isActive("/about") }}>
            About
          </a>
        </li>
        {
          SITE.showArchives && (
            <li class="col-span-2">
              <LinkButton
                href="/archives"
                class:list={[
                  "focus-outline flex justify-center p-3 sm:p-1",
                  {
                    "active-nav [&>svg]:stroke-ac": isActive("/archives"),
                  },
                ]}
                title="Archives"
                aria-label="archives"
              >
                <IconArchive class="hidden sm:inline-block" />
                <span class="sm:sr-only">Archives</span>
              </LinkButton>
            </li>
          )
        }
      </ul>
    </nav>

    {/* Always-visible: Search + Settings gear */}
    <div class="flex items-center gap-1">
      <LinkButton
        href="/search"
        class:list={[
          "focus-outline flex p-1",
          { "[&>svg]:stroke-ac": isActive("/search") },
        ]}
        title="Search"
        aria-label="search"
      >
        <IconSearch />
        <span class="sr-only">Search</span>
      </LinkButton>

      {/* Settings gear with popover */}
      <div class="settings-wrapper relative">
        <button
          id="settings-btn"
          class="focus-outline size-8 p-1 hover:text-ac"
          title="Settings"
          aria-label="Settings"
          aria-expanded="false"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round"
            stroke-linejoin="round" class="size-5">
            <circle cx="12" cy="12" r="3" />
            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
          </svg>
        </button>

        <div id="settings-popover" class="settings-popover">
          {/* Wide mode */}
          <button id="wide-btn" class="settings-item" aria-pressed="false">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round"
              stroke-linejoin="round" class="size-4 shrink-0">
              <polyline points="15 3 21 3 21 9" />
              <polyline points="9 21 3 21 3 15" />
              <line x1="21" y1="3" x2="14" y2="10" />
              <line x1="3" y1="21" x2="10" y2="14" />
            </svg>
            <span>Wide mode</span>
            <span id="wide-status" class="settings-status">Off</span>
          </button>

          {/* Theme toggle */}
          {SITE.lightAndDarkMode && (
            <button id="theme-btn" class="settings-item" aria-live="polite">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round"
                stroke-linejoin="round" class="size-4 shrink-0">
                <circle cx="12" cy="12" r="5" />
                <line x1="12" y1="1" x2="12" y2="3" />
                <line x1="12" y1="21" x2="12" y2="23" />
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
                <line x1="1" y1="12" x2="3" y2="12" />
                <line x1="21" y1="12" x2="23" y2="12" />
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
              </svg>
              <span>Theme</span>
              <span id="theme-status" class="settings-status">Auto</span>
            </button>
          )}
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const menuItems = document.querySelector("#menu-items");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";

      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? "Open Menu" : "Close Menu");

      menuItems.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  toggleNav();

  // Settings popover
  function setupSettings() {
    const settingsBtn = document.querySelector("#settings-btn");
    const popover = document.querySelector("#settings-popover");
    if (!settingsBtn || !popover) return;

    settingsBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      const isOpen = popover.classList.contains("active");
      popover.classList.toggle("active");
      settingsBtn.setAttribute("aria-expanded", isOpen ? "false" : "true");
    });

    // Click outside to dismiss
    document.addEventListener("click", (e) => {
      if (!popover.contains(e.target as Node) && e.target !== settingsBtn) {
        popover.classList.remove("active");
        settingsBtn.setAttribute("aria-expanded", "false");
      }
    });
  }

  // Wide mode toggle
  function setupWideMode() {
    const btn = document.querySelector("#wide-btn");
    const status = document.querySelector("#wide-status");
    if (!btn) return;

    const updateUI = (isWide: boolean) => {
      if (status) status.textContent = isWide ? "On" : "Off";
      btn.setAttribute("aria-pressed", isWide ? "true" : "false");
    };

    // Restore from localStorage
    const isWide = localStorage.getItem("wide-mode") === "true";
    if (isWide) {
      document.documentElement.setAttribute("data-wide", "");
    }
    updateUI(isWide);

    btn.addEventListener("click", () => {
      const wasWide = document.documentElement.hasAttribute("data-wide");
      if (wasWide) {
        document.documentElement.removeAttribute("data-wide");
        localStorage.setItem("wide-mode", "false");
      } else {
        document.documentElement.setAttribute("data-wide", "");
        localStorage.setItem("wide-mode", "true");
      }
      updateUI(!wasWide);
    });
  }

  setupSettings();
  setupWideMode();

  // Runs on view transitions navigation
  document.addEventListener("astro:after-swap", () => {
    toggleNav();
    setupSettings();
    setupWideMode();
  });
</script>
