---
import { fetchOGData } from "@/utils/og-fetch";

type Props = {
  url: string;
  title?: string;
  description?: string;
  image?: string;
  class?: string;
};

const { url, title, description, image, class: className } = Astro.props;

const og = await fetchOGData(url, { title, description, image });
const domain = og.siteName || new URL(url).hostname;
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class:list={["og-card", className]}
>
  {og.image && (
    <img
      src={og.image}
      alt=""
      class="og-card-image"
      loading="lazy"
    />
  )}
  <div class="og-card-content">
    {og.title && <div class="og-card-title">{og.title}</div>}
    {og.description && <div class="og-card-description">{og.description}</div>}
    <div class="og-card-domain">
      {og.favicon && (
        <img src={og.favicon} alt="" class="og-card-favicon" loading="lazy" />
      )}
      <span>{domain}</span>
    </div>
  </div>
</a>

<style>
@reference "tailwindcss/theme";
  .og-card {
    @apply flex border border-bd rounded-lg overflow-hidden my-4
           no-underline hover:border-ac/60 transition-colors;
  }

  .og-card-image {
    @apply w-32 sm:w-40 flex-shrink-0 object-cover bg-mt border-0;
  }

  .og-card-content {
    @apply flex flex-col justify-center gap-1 p-3 min-w-0;
  }

  .og-card-title {
    @apply text-fg font-semibold text-sm line-clamp-2;
  }

  .og-card-description {
    @apply text-fg/60 text-xs line-clamp-2;
  }

  .og-card-domain {
    @apply text-fg/40 text-xs flex items-center gap-1 mt-1;
  }

  .og-card-favicon {
    @apply w-4 h-4 border-0;
  }

  /* Stack image on narrow screens */
  @media (max-width: 480px) {
    .og-card {
      @apply flex-col;
    }
    .og-card-image {
      @apply w-full h-32;
    }
  }
</style>
